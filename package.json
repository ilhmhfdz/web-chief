{
  "name": "chief-supplies",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run kill:wa && concurrently --names \"NEXT,WA-BOT\" --prefix-colors \"cyan,green\" \"next dev\" \"npm run wa:dev\"",
    "kill:wa": "lsof -ti :3003 | xargs kill -9 2>/dev/null; pkill -f '.wwebjs_auth' 2>/dev/null; pkill -f 'chromium' 2>/dev/null; sleep 1; exit 0",
    "wa:dev": "cd whatsapp-service && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@mediapipe/tasks-vision": "^0.10.18",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-text-align": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.468.0",
    "mongoose": "^8.9.5",
    "next": "14.2.29",
    "openai": "^6.36.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-webcam": "^7.2.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.29",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
